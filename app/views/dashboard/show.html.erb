<div class="min-h-screen bg-gradient-to-br from-gray-950 via-gray-900 to-purple-950">
  <%# Navigation %>
  <nav class="border-b border-gray-800 bg-gray-900/50 backdrop-blur sticky top-0 z-10">
    <div class="max-w-2xl mx-auto px-4 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <h1 class="text-lg font-bold text-white">PiggyBank</h1>
      </div>
      <div class="flex items-center gap-3">
        <%# Network badge %>
        <span class="flex items-center gap-1.5 text-xs text-gray-400 bg-gray-800 px-2.5 py-1.5 rounded-lg">
          <span class="w-1.5 h-1.5 bg-yellow-400 rounded-full"></span>
          Devnet
        </span>

        <%# Wallet address %>
        <span class="text-gray-400 text-xs font-mono bg-gray-800 px-2.5 py-1.5 rounded-lg">
          <%= current_user.wallet_address[0..3] %>...<%= current_user.wallet_address[-4..] %>
        </span>

        <%# Disconnect %>
        <%= link_to "Disconnect", logout_path, data: { turbo_method: :delete }, class: "text-gray-500 hover:text-white text-xs cursor-pointer transition-colors" %>
      </div>
    </div>
  </nav>

  <div class="max-w-2xl mx-auto px-4 py-8 space-y-6" data-controller="auto-refresh piggy-bank" data-auto-refresh-interval-value="60" data-piggy-bank-build-lock-url-value="/locks/build" data-piggy-bank-build-unlock-url-value="/locks/build_unlock" data-piggy-bank-wallet-address-value="<%= current_user.wallet_address %>" data-piggy-bank-dashboard-url-value="<%= dashboard_path %>">
    <%# Lock Form Card %>
    <div class="bg-gray-800/50 backdrop-blur border border-gray-700/50 rounded-2xl p-6">
      <h2 class="text-lg font-semibold text-white mb-4">Lock SOL</h2>

      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-gray-400 text-xs font-medium mb-2">Amount (SOL)</label>
          <div class="flex gap-2 mb-2">
            <% [0.1, 0.2, 0.5].each do |amt| %>
              <button data-action="click->piggy-bank#setAmount" data-amount="<%= amt %>"
                class="flex-1 cursor-pointer bg-gray-700/50 hover:bg-gray-600/50 text-white text-sm py-2 rounded-lg transition-colors border border-gray-600/50">
                <%= amt %>
              </button>
            <% end %>
          </div>
          <input type="number" step="0.01" min="0.01" data-piggy-bank-target="amount" placeholder="Custom"
            class="w-full bg-gray-900/50 border border-gray-600/50 text-white rounded-lg px-3 py-2 text-sm focus:border-purple-500 focus:outline-none">
        </div>

        <div>
          <label class="block text-gray-400 text-xs font-medium mb-2">Duration</label>
          <div class="flex gap-2 mb-2">
            <% [2, 5, 10].each do |dur| %>
              <button data-action="click->piggy-bank#setDuration" data-duration="<%= dur %>"
                class="flex-1 cursor-pointer bg-gray-700/50 hover:bg-gray-600/50 text-white text-sm py-2 rounded-lg transition-colors border border-gray-600/50">
                <%= dur %>m
              </button>
            <% end %>
          </div>
          <input type="number" min="1" data-piggy-bank-target="duration" placeholder="Minutes"
            class="w-full bg-gray-900/50 border border-gray-600/50 text-white rounded-lg px-3 py-2 text-sm focus:border-purple-500 focus:outline-none">
        </div>
      </div>

      <button data-action="click->piggy-bank#lock" data-piggy-bank-target="lockBtn"
        class="w-full cursor-pointer bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white font-semibold py-3 rounded-xl transition-all duration-200">
        Lock SOL
      </button>

      <div data-piggy-bank-target="status" class="hidden mt-4 p-3 rounded-lg text-sm text-center"></div>
    </div>

    <%# Locks List %>
    <div id="locks-list">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-white">Your Locks</h2>
        <% if @locks.any? %>
          <span class="text-gray-500 text-xs"><%= @locks.size %> lock<%= @locks.size == 1 ? "" : "s" %></span>
        <% end %>
      </div>

      <% if @locks.empty? %>
        <div class="bg-gray-800/50 backdrop-blur border border-gray-700/50 rounded-2xl p-10 text-center">
          <svg class="w-10 h-10 text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <p class="text-gray-400 text-sm">No locks yet</p>
          <p class="text-gray-500 text-xs mt-1">Lock some SOL to get started</p>
        </div>
      <% else %>
        <div class="space-y-3">
          <% @locks.each do |lock| %>
            <%= render "locks/lock_card", lock: lock %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Devnet notice %>
    <div class="text-center pt-4">
      <p class="text-gray-600 text-xs">
        Running on Solana Devnet &mdash;
        <a href="https://faucet.solana.com" target="_blank" class="text-purple-400/60 hover:text-purple-400 transition-colors">Get free SOL</a>
      </p>
    </div>
  </div>
</div>
