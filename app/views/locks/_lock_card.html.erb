<% expired = lock.exp < Time.now.to_i %>
<% remaining = [lock.exp - Time.now.to_i, 0].max %>
<div class="bg-gray-800/50 backdrop-blur border border-gray-700/50 rounded-2xl p-5"
     data-controller="countdown"
     data-countdown-expires-at-value="<%= lock.exp %>"
     data-countdown-expired-value="<%= expired %>">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-3">
      <span class="text-xl font-bold text-white"><%= "%.4f" % lock.sol_balance %> SOL</span>
      <% if expired %>
        <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-900/50 text-green-400 border border-green-800">Ready</span>
      <% else %>
        <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-purple-900/50 text-purple-400 border border-purple-800" data-countdown-target="badge">Locked</span>
      <% end %>
    </div>

    <% if expired %>
      <button data-action="click->piggy-bank#unlock" data-lock-pubkey="<%= lock.pubkey %>"
        class="cursor-pointer bg-green-600 hover:bg-green-500 text-white text-sm font-semibold py-2 px-5 rounded-xl transition-colors">
        Unlock
      </button>
    <% end %>
  </div>

  <% unless expired %>
    <%# Progress bar %>
    <div class="w-full bg-gray-700/50 rounded-full h-1.5 mb-2">
      <div data-countdown-target="progress"
           class="bg-gradient-to-r from-purple-500 to-blue-500 h-1.5 rounded-full transition-all duration-1000"
           style="width: 0%"></div>
    </div>
  <% else %>
    <div class="w-full bg-gray-700/50 rounded-full h-1.5 mb-2">
      <div class="bg-green-500 h-1.5 rounded-full" style="width: 100%"></div>
    </div>
  <% end %>

  <div class="flex items-center justify-between">
    <div class="text-gray-400 text-xs">
      <% if expired %>
        <span class="text-green-400">Ready to unlock</span>
      <% else %>
        <span data-countdown-target="timer">Unlocks in <%= remaining / 60 %>m <%= remaining % 60 %>s</span>
      <% end %>
    </div>
    <a href="https://explorer.solana.com/address/<%= lock.pubkey %>?cluster=devnet" target="_blank"
       class="text-gray-500 hover:text-purple-400 text-xs transition-colors font-mono">
      <%= lock.pubkey[0..5] %>...<%= lock.pubkey[-4..] %>
    </a>
  </div>
</div>
