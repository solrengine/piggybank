<% expired = lock.exp < Time.now.to_i %>
<div class="bg-gray-800/50 backdrop-blur border border-gray-700 rounded-2xl p-5">
  <div class="flex items-center justify-between">
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl font-bold text-white"><%= "%.4f" % lock.sol_balance %> SOL</span>
        <% if expired %>
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-900/50 text-green-400 border border-green-800">Expired</span>
        <% else %>
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-purple-900/50 text-purple-400 border border-purple-800">Active</span>
        <% end %>
      </div>
      <div class="text-gray-400 text-sm space-y-1">
        <p>Expires: <%= Time.at(lock.exp).strftime("%b %d, %Y %H:%M:%S") %></p>
        <p class="text-gray-500 text-xs">
          <a href="https://explorer.solana.com/address/<%= lock.pubkey %>?cluster=devnet" target="_blank" class="hover:text-purple-400 transition-colors">
            <%= lock.pubkey[0..7] %>...<%= lock.pubkey[-4..] %>
          </a>
        </p>
      </div>
    </div>

    <% if expired %>
      <button data-action="click->piggy-bank#unlock" data-lock-pubkey="<%= lock.pubkey %>"
        class="cursor-pointer bg-green-600 hover:bg-green-500 text-white font-semibold py-2 px-6 rounded-xl transition-colors">
        Unlock
      </button>
    <% end %>
  </div>
</div>
